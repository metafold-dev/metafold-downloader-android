rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /license_requests/{licenseId} {
      allow get: if licenseId.matches('^[a-f0-9]{64}$');
      allow list: if false;
      allow create: if licenseId.matches('^[a-f0-9]{64}$')
        && request.resource.data.keys().hasOnly([
          'email',
          'deviceId',
          'deviceLabel',
          'packageName',
          'appVersion',
          'status',
          'requestId',
          'owner',
          'expiresAt',
          'licenseKey',
          'createdAt'
        ])
        && request.resource.data.email is string
        && request.resource.data.deviceId is string
        && request.resource.data.status == 'pending'
        && request.resource.data.owner == ''
        && request.resource.data.expiresAt == ''
        && request.resource.data.licenseKey == '';
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
